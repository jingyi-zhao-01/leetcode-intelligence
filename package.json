{
  "name": "leetcode-qa",
  "private": true,
  "workspaces": [
    "services/leetcode-intelligence-service",
    "services/leetcode-mcp-service",
    "services/leetcode-submission-service"
  ],
  "scripts": {
    "lint": "eslint --no-error-on-unmatched-pattern \"services/ingestor/**/*.{js,mjs,cjs,ts,mts,cts}\" \"services/leetcode-submission-service/**/*.{js,mjs,cjs,ts,mts,cts}\"",
    "lint:fix": "eslint --no-error-on-unmatched-pattern \"services/ingestor/**/*.{js,mjs,cjs,ts,mts,cts}\" \"services/leetcode-submission-service/**/*.{js,mjs,cjs,ts,mts,cts}\" --fix",
    "postinstall": "prisma generate --schema services/shared/prisma/schema.prisma",
    "test": "vitest run",
    "format": "prettier --write \"services/**/*.{js,cjs,mjs,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"services/**/*.{js,cjs,mjs,ts,tsx,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "prettier": "^3.6.2",
    "prisma": "^5.22.0",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
