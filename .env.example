# PostgreSQL connection string used by Prisma and service persistence.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/neondb?sslmode=require"

# OpenRouter API key for LLM calls.
# Get it from: https://openrouter.ai/keys
OPEN_ROUTER_API_KEY="your-openrouter-api-key"

# Model identifier used for generation/scoring on OpenRouter.
# Example: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
MODEL="openai/gpt-4o-mini"

# Discord bot token for Discord client mode (optional if CLI-only).
DISCORD_BOT_TOKEN="your-discord-bot-token"

# Target Discord channel ID for posting prompts/results (optional if CLI-only).
DISCORD_CHANNEL_ID="your-discord-channel-id"

# HTTP port used by the intelligence service.
INTELLIGENCE_PORT=8030

# HTTP bind host of the intelligence service.
# Use 0.0.0.0 for container/network access, 127.0.0.1 for local-only.
INTELLIGENCE_HOST="0.0.0.0"

# Cron expression (server timezone) for scheduled intelligence runs.
# Example: "0 9 * * *" = every day at 09:00
INTELLIGENCE_CRON="0 9 * * *"

# Max number of problem candidates fetched before weighted selection.
INTELLIGENCE_MAX_CANDIDATES=500

# Size of the recent candidate window used for final random/weighted pick.
INTELLIGENCE_SELECTION_WINDOW=200

# Minimum selection weight floor for scoring-based sampling.
INTELLIGENCE_MIN_WEIGHT=0.25

# Maximum selection weight cap for scoring-based sampling.
INTELLIGENCE_MAX_WEIGHT=5
