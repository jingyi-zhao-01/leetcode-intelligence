# PostgreSQL connection string used by Prisma and service persistence.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/neondb?sslmode=require"

# OpenRouter API key for LLM calls.
# Get it from: https://openrouter.ai/keys
OPEN_ROUTER_API_KEY="your-openrouter-api-key"

# Model identifier used for generation/scoring on OpenRouter.
# Example: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
MODEL="openai/gpt-4o-mini"

# Default model for submission failure analysis.
# This matches the old CodeCompanion/OpenRouter default used by the Lua-side assistant.
FAILURE_ANALYSIS_MODEL="qwen/qwen3-coder-next"

# Discord bot token for Discord client modes.
DISCORD_BOT_TOKEN="your-discord-bot-token"

# Prompt Discord channel used for nudges and reply scoring.
PROMPT_DISCORD_CHANNEL_ID="your-prompt-channel-id"

# Recommendation Discord channel used for periodic focus pushes.
RECOMMEND_DISCORD_CHANNEL_ID="your-recommend-channel-id"

# HTTP port used by the intelligence service.
INTELLIGENCE_PORT=8030

# HTTP bind host of the intelligence service.
# Use 0.0.0.0 for container/network access, 127.0.0.1 for local-only.
INTELLIGENCE_HOST="0.0.0.0"

# Cron expression (server timezone) for scheduled prompt runs.
# Example: "0 9 * * *" = every day at 09:00
INTELLIGENCE_PROMPT_CRON="0 9 * * *"

# Cron expression for periodic focus recommendation generation.
# Example: "0 20 * * *" = every day at 20:00
INTELLIGENCE_RECOMMEND_CRON="0 20 * * *"

# Number of questions returned in each recommendation batch.
INTELLIGENCE_RECOMMEND_TOP_K=5

# Lookback window (days) for submission/prompt metrics in recommendation scoring.
INTELLIGENCE_RECOMMEND_LOOKBACK_DAYS=30

# Max number of problem candidates fetched before weighted selection.
INTELLIGENCE_MAX_CANDIDATES=500

# Size of the recent candidate window used for final random/weighted pick.
INTELLIGENCE_SELECTION_WINDOW=200

# JSON array of prompt cooldown rules. First matching rule wins.
# Once a question is prompted, it is dropped from the prompt pipeline until its cooldown expires.
# Example:
# [
#   { "name": "accepted", "cooldownHours": 72, "statuses": ["Accepted"] },
#   { "name": "default", "cooldownHours": 24 }
# ]
INTELLIGENCE_PROMPT_COOLDOWN_RULES='[{"name":"default","cooldownHours":24}]'

# Minimum selection weight floor for scoring-based sampling.
INTELLIGENCE_MIN_WEIGHT=0.25

# Maximum selection weight cap for scoring-based sampling.
INTELLIGENCE_MAX_WEIGHT=5
