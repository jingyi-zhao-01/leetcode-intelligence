service_runtime: {
  label: "Runtime orchestration"
  direction: right
  class: runtime_cloud

  service_stack: {
    label: "runtime entrypoints"
    direction: down
    style.fill: "#dbeafe"
    style.stroke: "#1d4ed8"
    style.stroke-width: 2

    intelligence_service: {
      label: "intelligence_service"
      class: local_core
    }

    intelligence_server: {
      label: "intelligence_server"
      class: cloud_intelligence
    }

    prompt_listener: {
      label: "prompt_listener"
      class: cloud_intelligence
    }
  }

  service_dispatch: {
    label: "delivery adapters"
    direction: right
    style.fill: "#e0f2fe"
    style.stroke: "#1d4ed8"
    style.stroke-width: 2

    prompt_dispatch: {
      label: "prompt_dispatch"
      class: cloud_intelligence
    }

    recommender: {
      label: "recommender"
      class: cloud_intelligence
    }
  }
  scoring_core: @core-domain.service_runtime.scoring_core
  recommendation_core: @core-domain.service_runtime.recommendation_core
  weight_model: @core-domain.service_runtime.weight_model
}
