...@styles
...@clients.clients

direction: down

discord_band: {
  label: "Discord boundary"
  direction: right
  style.fill: "#eef2ff"
  style.stroke: "#c7d2fe"
  style.stroke-width: 1

  discord_clients: @clients.discord_side.discord_clients
  discord: @clients.discord_side.discord
}

runtime_band: {
  label: "Service runtime"
  direction: down
  class: runtime_cloud

  ingress_row: {
    label: ""
    direction: right
    style.stroke-width: 0
    style.fill: "transparent"

    intelligence_server: @runtime.service_runtime.service_stack.intelligence_server
    intelligence_service: @runtime.service_runtime.service_stack.intelligence_service
  }

  worker_row: {
    label: ""
    direction: right
    style.stroke-width: 0
    style.fill: "transparent"

    prompt_dispatch: @runtime.service_runtime.service_dispatch.prompt_dispatch
    prompt_listener: @runtime.service_runtime.service_stack.prompt_listener
    recommender: @runtime.service_runtime.service_dispatch.recommender
  }

  analysis_row: {
    label: ""
    direction: right
    style.stroke-width: 0
    style.fill: "transparent"

    scoring_core: @core-domain.service_runtime.scoring_core
    recommendation_core: @core-domain.service_runtime.recommendation_core
    weight_model: @core-domain.service_runtime.weight_model
  }
}

data_band: {
  label: "External dependencies"
  direction: right
  style.fill: "#eef2ff"
  style.stroke: "#c7d2fe"
  style.stroke-width: 1

  postgres: @clients.data_side.postgres
  openrouter: @clients.data_side.openrouter
}

discord_band.discord_clients <-> discord_band.discord: "Discord events + bot messages"

discord_band.discord_clients -> runtime_band.worker_row.prompt_listener: "commands + replies"
runtime_band.ingress_row.intelligence_server -> runtime_band.ingress_row.intelligence_service: "hosts runtime"

runtime_band.ingress_row.intelligence_service -> runtime_band.worker_row.prompt_dispatch: "schedule prompts"
runtime_band.ingress_row.intelligence_service -> runtime_band.worker_row.prompt_listener: "listen for replies"
runtime_band.ingress_row.intelligence_service -> runtime_band.worker_row.recommender: "request focus pushes"

runtime_band.worker_row.prompt_dispatch -> discord_band.discord_clients: "scheduled prompts"
runtime_band.worker_row.recommender -> discord_band.discord_clients: "focus pushes"
runtime_band.worker_row.prompt_listener -> runtime_band.ingress_row.intelligence_service: "score request"
runtime_band.worker_row.prompt_listener -> runtime_band.analysis_row.scoring_core: "reply scoring"

runtime_band.ingress_row.intelligence_service -> runtime_band.analysis_row.scoring_core: "prompt generation"
runtime_band.ingress_row.intelligence_service -> runtime_band.analysis_row.recommendation_core: "ranking + narrative inputs"

runtime_band.analysis_row.scoring_core -> runtime_band.analysis_row.weight_model: "next weight selection"
runtime_band.analysis_row.recommendation_core -> runtime_band.analysis_row.weight_model: "normalized signal"

runtime_band.ingress_row.intelligence_service -> data_band.postgres: "shared Prisma schema"
runtime_band.analysis_row.scoring_core -> data_band.openrouter: "LLM scoring"
runtime_band.analysis_row.recommendation_core -> data_band.openrouter: "narrative generation"
