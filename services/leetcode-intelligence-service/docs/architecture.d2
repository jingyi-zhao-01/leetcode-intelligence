...@styles
...@clients.clients

direction: down

discord_boundary: {
  label: "Discord boundary"
  direction: down
  style.fill: "#eef2ff"
  style.stroke: "#c7d2fe"
  style.stroke-width: 1

  discord: @clients.discord_side.discord
}

runtime_orchestration: {
  label: "Runtime orchestration"
  direction: down
  class: runtime_cloud

  entrypoints: {
    label: "entrypoints"
    direction: right
    style.stroke-width: 0
    style.fill: "transparent"

    intelligence_server: {
      label: "intelligence_server"
      class: cloud_intelligence
    }

    discord_adapters: {
      label: "discord adapters\nprompt_dispatch / prompt_listener / recommender"
      class: cloud_intelligence
    }

    discord_clients: @clients.discord_side.discord_clients
  }

  intelligence_runtime: {
    label: "intelligence_runtime"
    class: local_core
  }
}

domain_services: {
  label: "Domain services"
  direction: right
  style.fill: "#f8fafc"
  style.stroke: "#94a3b8"
  style.stroke-width: 2

  scoring_core: @core-domain.service_runtime.scoring_core
  recommendation_core: @core-domain.service_runtime.recommendation_core
  weight_model: @core-domain.service_runtime.weight_model
}

integrations: {
  label: "Persistence and external services"
  direction: right
  style.fill: "#eef2ff"
  style.stroke: "#c7d2fe"
  style.stroke-width: 1

  postgres: @clients.data_side.postgres
  openrouter: @clients.data_side.openrouter
}

runtime_orchestration.entrypoints.discord_clients <-> discord_boundary.discord: "Discord events + bot messages"

runtime_orchestration.entrypoints.intelligence_server -> runtime_orchestration.intelligence_runtime: "HTTP requests"
runtime_orchestration.entrypoints.discord_adapters -> runtime_orchestration.intelligence_runtime: "trigger prompt / score reply / recommend"
runtime_orchestration.intelligence_runtime -> runtime_orchestration.entrypoints.discord_adapters: "prompt / feedback / push payloads"

runtime_orchestration.entrypoints.discord_adapters -> runtime_orchestration.entrypoints.discord_clients: "send prompts + recommendations"
runtime_orchestration.entrypoints.discord_clients -> runtime_orchestration.entrypoints.discord_adapters: "commands + replies"

runtime_orchestration.intelligence_runtime -> domain_services.scoring_core: "prompt generation + reply scoring"
runtime_orchestration.intelligence_runtime -> domain_services.recommendation_core: "focus recommendation"

domain_services.scoring_core -> domain_services.weight_model: "next weight"
domain_services.recommendation_core -> domain_services.weight_model: "normalized signal"

runtime_orchestration.intelligence_runtime -> integrations.postgres: "prompt events + scores + weights"
domain_services.scoring_core -> integrations.openrouter: "LLM scoring"
domain_services.recommendation_core -> integrations.openrouter: "narrative generation"
