{
  "name": "leetcode-intelligence-service-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:unit": "vitest run __test__/core.unit.test.ts __test__/client.unit.test.ts __test__/algorithms/*.test.ts",
    "test:integration": "vitest run __test__/intelligence.integration.test.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:openrouter-model": "tsx __test__/openrouter-model.test.ts",
    "intelligence-cli": "tsx src/cli.ts",
    "intelligence-prompt-dispatch": "tsx src/cli/prompt-dispatch.ts scheduled",
    "intelligence-prompt-dispatch-once": "tsx src/cli/prompt-dispatch.ts once",
    "intelligence-prompt-listener": "tsx src/prompt-response.ts",
    "intelligence-recommender": "tsx src/cli/recommender.ts scheduled",
    "intelligence-recommender-once": "tsx src/cli/recommender.ts once",
    "intelligence-server": "tsx src/server.ts",
    "intelligence-server-dev": "tsx watch src/server.ts"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.12.35",
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "pino": "^9.14.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.8"
  }
}
