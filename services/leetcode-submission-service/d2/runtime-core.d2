local_runtime: {
  label: "Strict local"
  direction: down
  class: runtime_local

  submission_svc: {
    label: "submission_service"
    class: local_core
  }

  action_router: {
    label: "action_router"
    class: local_core
  }

  submission_pipeline: {
    label: "submission_pipeline"
    class: local_core
  }

  companion_http: {
    label: "companion_http\nOpenAI-compatible"
    class: local_core
  }

  companion_chat: {
    label: "companion_chat"
    class: local_analysis
  }

  session_scope: {
    label: "session_scope\nactive in-memory"
    class: cache_store
  }

  session_persistence: {
    label: "session_persistence\nMem0 snapshot"
    class: local_analysis
  }

  ...@timer.runtime
  ...@static-analysis.runtime
  ...@storage.runtime
}
