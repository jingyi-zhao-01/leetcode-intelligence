...@services/shared/d2/architecture-style

direction: right

nvim: {
  label: "nvim\nentry point"
  class: entry_point
}

cli: {
  label: "cli\nentry point"
  class: entry_point
}

llm_clients: {
  label: "LLM clients\nexternal clients"
  class: external_ai
}

mem0: {
  label: "Mem0\nsession memory"
  class: external_ai
}

local_runtime: {
  label: "Strict local"
  class: runtime_local

  submission_svc: {
    label: "submission_service"
    class: local_core
  }
}

cloud_runtime: {
  label: "Can be cloud hosted"
  direction: down
  class: runtime_cloud

  mcp_svc: {
    label: "mcp_service"
    class: local_analysis
  }

  ingestor: {
    label: "ingestor"
    class: cloud_ingestor
  }

  intelligence_svc: {
    label: "intelligence_service"
    class: cloud_intelligence
  }
}

prisma_schema: {
  label: "shared prisma schema\ndata plane"
  class: local_data
}

db: {
  label: "PostgreSQL\ndata plane"
  class: data_plane
}

leetcode_api: {
  label: "LeetCode API\nexternal"
  class: external_api
}

discord: {
  label: "Discord\nexternal"
  class: external_user
}

nvim -> local_runtime.submission_svc: "JSON over TCP"
cli -> local_runtime.submission_svc: "CLI / HTTP"
llm_clients -> cloud_runtime.mcp_svc: "MCP"

leetcode_api -> cloud_runtime.ingestor: "GraphQL"
cloud_runtime.intelligence_svc -> discord: "Scheduled Prompt Submitted Question for Answering\n Scheduled Recommend Questions to Focus "

local_runtime.submission_svc -> prisma_schema: "Prisma ORM"
local_runtime.submission_svc -> mem0: "session snapshots"
cloud_runtime.mcp_svc -> prisma_schema: "Prisma ORM"
cloud_runtime.ingestor -> prisma_schema: "Prisma ORM"
cloud_runtime.intelligence_svc -> prisma_schema: "Prisma ORM"

prisma_schema -> db: "SQL"
