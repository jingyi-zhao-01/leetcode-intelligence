generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id              String   @id @default(cuid())
  difficulty      String
  title           String
  titleSlug       String   @unique
  freqBar         Float?
  topicTags       String[]
  relatedProblems String[]
  content         String?
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)
  
  // submissions     Submission[]

  @@index([topicTags], type: Gin)
}

model Submission {
  id               String   @id @default(cuid())
  titleSlug        String?
  content          String
  status           String
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  submissionDetails Json?
  
  // question         Question? @relation(fields: [titleSlug], references: [titleSlug])
}