generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PatternTagDimension {
  template
  approach
  data_structure
}

enum PatternTagSource {
  seeded
  manually_created
  llm_generated
}

enum PatternTagKind {
  template_group
  tag
}

model Question {
  id              String   @id @default(cuid())
  difficulty      String
  title           String
  titleSlug       String   @unique
  freqBar         Float?
  topicTags       String[]
  relatedProblems String[]
  content         String?
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  @@index([topicTags], type: Gin)
}

model Submission {
  id                     String                  @id @default(cuid())
  titleSlug              String?
  content                String
  status                 String
  templateBenchmarkOptOut Boolean                @default(false)
  createdAt              DateTime                @default(now()) @db.Timestamptz(6)
  submissionDetails      Json?
  isCheat                Boolean                 @default(false)
  timeSpentMinutes       Int?
  timeComplexity         String?
  spaceComplexity        String?
  thought                String?
  mistake                String?
  SubmissionPatternTag   SubmissionPatternTag[]
  TemplateBenchmarkScore TemplateBenchmarkScore[]

  @@index([timeComplexity])
  @@index([spaceComplexity])
}

model PatternTag {
  id                     String                  @id @default(cuid())
  key                    String                  @unique
  label                  String
  dimension              PatternTagDimension
  kind                   PatternTagKind          @default(tag)
  source                 PatternTagSource        @default(manually_created)
  description            String?                 @db.Text
  metadata               Json?
  parentId               String?
  isActive               Boolean                 @default(true)
  sortOrder              Int                     @default(0)
  createdAt              DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @db.Timestamptz(6)
  parent                 PatternTag?             @relation("PatternTagHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children               PatternTag[]            @relation("PatternTagHierarchy")
  SubmissionPatternTag   SubmissionPatternTag[]
  TemplateBenchmarkScore TemplateBenchmarkScore[]

  @@index([dimension])
  @@index([kind])
  @@index([source])
  @@index([parentId])
}

model SubmissionPatternTag {
  id           String     @id @default(cuid())
  submissionId String
  patternTagId String
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  Submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  PatternTag   PatternTag @relation(fields: [patternTagId], references: [id], onDelete: Cascade)

  @@unique([submissionId, patternTagId])
  @@index([submissionId])
  @@index([patternTagId])
}

model TemplateBenchmarkScore {
  id                String     @id @default(cuid())
  submissionId      String
  patternTagId      String
  templateKey       String
  model             String
  score             Int
  confidence        Int
  reason            String?    @db.Text
  evidence          String[]   @default([])
  excludedGroupKeys String[]   @default([])
  createdAt         DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @db.Timestamptz(6)
  Submission        Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  PatternTag        PatternTag @relation(fields: [patternTagId], references: [id], onDelete: Cascade)

  @@unique([submissionId, patternTagId])
  @@index([submissionId])
  @@index([patternTagId])
  @@index([score])
}
