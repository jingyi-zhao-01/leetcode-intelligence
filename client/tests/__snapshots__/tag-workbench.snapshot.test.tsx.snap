// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TagWorkbench snapshots > keeps the submission code panel on a single scroll contract 1`] = `
".submission-utility-grid .context-panel-shell {
  height: clamp(320px, 38vh, 520px);
  min-height: 320px;
  max-height: 520px;
  overflow: auto;
}

.submission-utility-grid .context-panel-code .submission-code,
.submission-utility-grid .context-panel-code .python-code,
.submission-utility-grid .context-panel-statement .problem-description {
  min-height: 100%;
  max-height: none;
  overflow: visible !important;
}"
`;

exports[`TagWorkbench snapshots > keeps the template control plane header wrapping contract 1`] = `
".template-plane-header > div,
.template-plane-header-actions,
.plane-complexity {
  min-width: 0;
}

.template-plane-header h2 {
  margin: 0;
  font-size: 24px;
  line-height: 1.05;
}"
`;

