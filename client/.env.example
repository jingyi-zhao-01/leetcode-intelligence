# BFF service backing the Vercel client
BFF_SERVICE_URL=https://<public-intelligence-service-host>
BFF_TOKEN=<shared-bff-token>

# Admin write gate (required for mutation actions)
# Set this to a strong secret value and keep it in Vercel envs.
ADMIN_PASSWORD=change-me

# Optional alternative session token. If unset, ADMIN_PASSWORD is reused.
# Recommended to use a separate random token.
ADMIN_SESSION_TOKEN=<long-random-string>
ADMIN_COOKIE_NAME=leetcode-qa-admin
ADMIN_COOKIE_MAX_AGE_SECONDS=28800

# Production-only non-admin IP rate limiting via Upstash Redis.
UPSTASH_REDIS_REST_URL=https://<upstash-rest-url>
UPSTASH_REDIS_REST_TOKEN=<upstash-rest-token>
NON_ADMIN_RATE_LIMIT_MAX_REQUESTS=120
NON_ADMIN_RATE_LIMIT_WINDOW_SECONDS=60
